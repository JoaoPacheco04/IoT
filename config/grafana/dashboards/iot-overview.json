      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-iot"
          },
          "query": "from(bucket: \"iot_dados\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"machine_metrics\")\n  |> filter(fn: (r) => r._field == \"alarm_code\")\n  |> last()\n  |> map(fn: (r) => ({ r with _value: if r.alarm == \"OK\" then float(v: 3) else if r.machine_state == \"RUNNING\" then float(v: 3) else if r.machine_state == \"WARMING\" then float(v: 2) else if r.machine_state == \"COOLING\" then float(v: 4) else if r.machine_state == \"IDLE\" then float(v: 1) else if r.machine_state == \"OFF\" then float(v: 0) else float(v: 5) }))",
          "refId": "A"
        }
      ],
      "title": "Machine State",
      "type": "stat"
    },
